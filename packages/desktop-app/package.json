{
  "name": "@netior/desktop-app",
  "version": "0.8.0",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "rebuild:electron": "electron-rebuild -f -o better-sqlite3",
    "rebuild:node": "node scripts/rebuild-native.js",
    "postinstall": "electron-rebuild -f -o better-sqlite3",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder",
    "package:win": "electron-builder --win",
    "clean": "rimraf out release",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm run rebuild:node",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@codingame/monaco-vscode-api": "^29.1.1",
    "@codingame/monaco-vscode-configuration-service-override": "^29.1.1",
    "@codingame/monaco-vscode-keybindings-service-override": "^29.1.1",
    "@codingame/monaco-vscode-terminal-service-override": "^29.1.1",
    "@codingame/monaco-vscode-theme-service-override": "^29.1.1",
    "@lezer/highlight": "^1.2.3",
    "@lezer/markdown": "^1.6.3",
    "@monaco-editor/react": "^4.7.0",
    "@netior/core": "workspace:*",
    "@netior/shared": "workspace:*",
    "@uiw/react-codemirror": "^4.25.9",
    "@xterm/addon-fit": "0.12.0-beta.191",
    "@xterm/addon-web-links": "0.13.0-beta.191",
    "@xterm/addon-webgl": "0.20.0-beta.190",
    "@xterm/xterm": "6.1.0-beta.191",
    "better-sqlite3": "^9.4.0",
    "codemirror-markdown-hybrid": "^1.2.2",
    "node-pty": "^1.1.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "remark-gfm": "^4.0.1",
    "vscode-icons-js": "^11.6.1",
    "zustand": "^4.4.7"
  },
  "build": {
    "appId": "com.netior.app",
    "productName": "Netior",
    "icon": "build/icons/netior-app-icon.png",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "!node_modules/**/*.{ts,map,md}",
      "!node_modules/**/{test,tests,__tests__}/**"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/bindings/**",
      "node_modules/file-uri-to-path/**",
      "node_modules/node-pty/**"
    ],
    "win": {
      "icon": "build/icons/netior-app-icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "build/icons/netior-app-icon.ico",
      "uninstallerIcon": "build/icons/netior-app-icon.ico"
    }
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@electron/rebuild": "^4.0.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.8",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "jsdom": "^29.0.1",
    "lucide-react": "^0.563.0",
    "postcss": "^8.4.33",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^2.1.9"
  }
}
